{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Variant Configuration Schema",
  "type": "object",
  "properties": {
    "webview_url": {
      "type": "string",
      "format": "uri"
    },
    "firebase_app_distribution_groups": {
      "type": "string"
    },
    "vconsole": {
      "type": "boolean",
      "description": "WebView にデバッグ用の vConsole を表示するか"
    }
  },
  "required": [
    "webview_url"
  ]
}
