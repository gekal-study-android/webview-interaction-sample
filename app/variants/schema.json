{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Build Variants Configuration Schema",
  "type": "object",
  "properties": {
    "debug": {
      "type": "object",
      "properties": {
        "webview_url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "webview_url"
      ]
    },
    "release": {
      "type": "object",
      "properties": {
        "webview_url": {
          "type": "string",
          "format": "uri"
        },
        "firebase_app_distribution_groups": {
          "type": "string"
        }
      },
      "required": [
        "webview_url",
        "firebase_app_distribution_groups"
      ]
    }
  },
  "required": [
    "debug",
    "release"
  ]
}
