<?xml version="1.0" encoding="utf-8"?>
<!--
  WebView (ブラウザウィンドウ) と JS <-> Native の双方向 (⇄) を表すアイコン。
  すべて単色の白で構成しているため、テーマアイコン用の monochrome にもそのまま使える。
  アダプティブアイコンのセーフゾーン (中央 66dp) 内に収めること。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      アダプティブアイコンのセーフゾーン (中央 66dp の円) に収まるよう、
      作画の中心 (52.75, 52.75) を基準に縮小してからアイコン中心 (54, 54) に寄せる。
    -->
    <group
        android:pivotX="52.75"
        android:pivotY="52.75"
        android:scaleX="0.86"
        android:scaleY="0.86"
        android:translateX="1.25"
        android:translateY="1.25">

        <!-- ブラウザウィンドウの枠 -->
        <path
            android:fillColor="#00000000"
            android:pathData="M33,32h42a7,7 0 0 1 7,7v30a7,7 0 0 1 -7,7h-42a7,7 0 0 1 -7,-7v-30a7,7 0 0 1 7,-7z"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="5"
            android:strokeLineJoin="round" />

        <!-- タイトルバーの区切り線 -->
        <path
            android:fillColor="#00000000"
            android:pathData="M26,45L82,45"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="4" />

        <!-- タイトルバーのドット -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M34,36.3a2.2,2.2 0 1 1 0,4.4a2.2,2.2 0 1 1 0,-4.4z" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M42,36.3a2.2,2.2 0 1 1 0,4.4a2.2,2.2 0 1 1 0,-4.4z" />

        <!-- JS -> Native -->
        <path
            android:fillColor="#00000000"
            android:pathData="M37,54L61,54"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="5"
            android:strokeLineCap="round" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M72,54L61,48.5L61,59.5z" />

        <!-- Native -> JS -->
        <path
            android:fillColor="#00000000"
            android:pathData="M71,66L47,66"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="5"
            android:strokeLineCap="round" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M36,66L47,60.5L47,71.5z" />
    </group>
</vector>
